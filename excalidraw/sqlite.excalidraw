    {
      "id": "-wZHe9UJAy-6c9uZ3X2yo",
      "type": "text",
      "x": 761.4113972981763,
      "y": 919.3033854166664,
      "width": 649.5198974609375,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0f",
      "roundness": null,
      "seed": 1531006174,
      "version": 133,
      "versionNonce": 1836900574,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777554116645,
      "link": null,
      "locked": false,
      "text": "  Freeblock                                                               \n  +----------------------------------------------+                        \n  | Next Freeblock Offset     (2 bytes)   |                        \n  | Freeblock Size            (2 bytes)      |                        \n  | Unused Bytes              (...)            |                        \n  +----------------------------------------------+                        \n                                                                          \n  Fragment                                                                \n  +----------------------------------------------+                        \n  | 1~3 bytes unused                          |                        \n  +----------------------------------------------+                        \n                                                                          \n  说明：                                                                  \n  - >= 4 字节的空洞挂到 freeblock 链                                      \n  - 1~3 字节的小碎片不挂链                                                \n  - 所有碎片总字节数记在页头 offset 7",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  Freeblock                                                               \n  +----------------------------------------------+                        \n  | Next Freeblock Offset     (2 bytes)   |                        \n  | Freeblock Size            (2 bytes)      |                        \n  | Unused Bytes              (...)            |                        \n  +----------------------------------------------+                        \n                                                                          \n  Fragment                                                                \n  +----------------------------------------------+                        \n  | 1~3 bytes unused                          |                        \n  +----------------------------------------------+                        \n                                                                          \n  说明：                                                                  \n  - >= 4 字节的空洞挂到 freeblock 链                                      \n  - 1~3 字节的小碎片不挂链                                                \n  - 所有碎片总字节数记在页头 offset 7",
      "autoResize": true,
      "lineHeight": 1.25
    },
