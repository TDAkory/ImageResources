      "seed": 1818372190,
      "version": 250,
      "versionNonce": 373974046,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777949884942,
      "link": null,
      "locked": false,
      "text": "  In-Memory Transaction Model                                             \n  +-----------------------------------------------+                           \n  | Main Database Pages                      |                           \n  |  Page 1 / Page 2 / Page 3 / ...          |                           \n  +-----------------------------------------------+                           \n  | Rollback Journal (Memory Journal)       |                           \n  |  old page image / rollback records / ...  |                           \n  +-----------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  In-Memory Transaction Model                                             \n  +-----------------------------------------------+                           \n  | Main Database Pages                      |                           \n  |  Page 1 / Page 2 / Page 3 / ...          |                           \n  +-----------------------------------------------+                           \n  | Rollback Journal (Memory Journal)       |                           \n  |  old page image / rollback records / ...  |                           \n  +-----------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mi6KezH_K3cyTPHLyXVID",
      "type": "text",
      "x": 2229.881874341381,
      "y": -945.362937037105,
      "width": 620.43994140625,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "vW_cEvjpWqzlgMHv93k_O"
      ],
      "frameId": null,
      "index": "b0r",
      "roundness": null,
      "seed": 384865246,
      "version": 752,
      "versionNonce": 1843671134,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777949884942,
      "link": null,
      "locked": false,
      "text": "  MemJournal                                                              \n  +--------------------------------------+                                \n  | nChunkSize                          |                                \n  | pFirst --------------------------+   |                                \n  | endpoint                         |   |                                \n  | readpoint                        |   |                                \n  +-----------------------------------|---+                                \n                                     v                                    \n                            +-------------------+                          \n                            | FileChunk        |                          \n                            | zChunk[...]      |                          \n                            | pNext ----------> ...                       \n                            +------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  MemJournal                                                              \n  +--------------------------------------+                                \n  | nChunkSize                          |                                \n  | pFirst --------------------------+   |                                \n  | endpoint                         |   |                                \n  | readpoint                        |   |                                \n  +-----------------------------------|---+                                \n                                     v                                    \n                            +-------------------+                          \n                            | FileChunk        |                          \n                            | zChunk[...]      |                          \n                            | pNext ----------> ...                       \n                            +------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "bJryYnit76I2hotBOCOrE",
      "type": "text",
      "x": 1833.1681047454197,
      "y": 80.51055711917866,
      "width": 654.3192138671875,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
