      "updated": 1777554587452,
      "link": null,
      "locked": false,
      "text": "Table Leaf Cell\n+-----------------------------------------+\n| Payload Size         (varint)         | <- Variable-length integer\n| Rowid (Key)          (varint)         | <- 64-bit rowid\n| Payload Data        (bytes)         | <- Actual row data\n| Overflow Page Num (4 bytes, opt) | <- If payload overflows\n+------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Table Leaf Cell\n+-----------------------------------------+\n| Payload Size         (varint)         | <- Variable-length integer\n| Rowid (Key)          (varint)         | <- 64-bit rowid\n| Payload Data        (bytes)         | <- Actual row data\n| Overflow Page Num (4 bytes, opt) | <- If payload overflows\n+------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
