      "isDeleted": false,
      "boundElements": null,
      "updated": 1777862533633,
      "link": null,
      "locked": false,
      "text": "  Freeblock                                                               \n  +----------------------------------------------+                        \n  | Next Freeblock Offset     (2 bytes)   |                        \n  | Freeblock Size            (2 bytes)      |                        \n  | Unused Bytes              (...)            |                        \n  +----------------------------------------------+                        \n                                                                          \n  Fragment                                                                \n  +----------------------------------------------+                        \n  | 1~3 bytes unused                          |                        \n  +----------------------------------------------+                        \n                                                                          \n  说明：                                                                  \n  - >= 4 字节的空洞挂到 freeblock 链                                      \n  - 1~3 字节的小碎片不挂链                                                \n  - 所有碎片总字节数记在页头 offset 7",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  Freeblock                                                               \n  +----------------------------------------------+                        \n  | Next Freeblock Offset     (2 bytes)   |                        \n  | Freeblock Size            (2 bytes)      |                        \n  | Unused Bytes              (...)            |                        \n  +----------------------------------------------+                        \n                                                                          \n  Fragment                                                                \n  +----------------------------------------------+                        \n  | 1~3 bytes unused                          |                        \n  +----------------------------------------------+                        \n                                                                          \n  说明：                                                                  \n  - >= 4 字节的空洞挂到 freeblock 链                                      \n  - 1~3 字节的小碎片不挂链                                                \n  - 所有碎片总字节数记在页头 offset 7",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "BOaK7u2R6MH2ZIg4SDaOa",
      "type": "text",
      "x": -2238.767603771894,
      "y": 332.28724058877003,
      "width": 645.1198120117188,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "cc6hyGJpExVpxnHlAh7T9",
        "KvpjX044RLEU7z41oXFLJ"
      ],
      "frameId": null,
      "index": "b0k",
