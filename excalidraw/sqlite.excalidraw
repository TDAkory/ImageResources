      "seed": 574645534,
      "version": 345,
      "versionNonce": 1358466462,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777951614180,
      "link": null,
      "locked": false,
      "text": "  Rollback Journal Mode                                                   \n  +------------------+      +----------------------+                       \n  | main.db          |      | main.db-journal     |                       \n  | 主数据库文件    |<--->| 回滚日志             |                      \n  +------------------+      +----------------------+                       \n                                                                          \n  WAL Mode                                                                \n  +------------------+      +------------------+      +--------------------+  \n  | main.db          |      | main.db-wal      |      | main.db-shm      |  \n  | 主数据库文件    |<--->| WAL 追加日志   |<--->| wal-index / 锁区  |\n  +------------------+      +------------------+      +---------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  Rollback Journal Mode                                                   \n  +------------------+      +----------------------+                       \n  | main.db          |      | main.db-journal     |                       \n  | 主数据库文件    |<--->| 回滚日志             |                      \n  +------------------+      +----------------------+                       \n                                                                          \n  WAL Mode                                                                \n  +------------------+      +------------------+      +--------------------+  \n  | main.db          |      | main.db-wal      |      | main.db-shm      |  \n  | 主数据库文件    |<--->| WAL 追加日志   |<--->| wal-index / 锁区  |\n  +------------------+      +------------------+      +---------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "E0ZiJFu-_JIy46yIyYEcR",
