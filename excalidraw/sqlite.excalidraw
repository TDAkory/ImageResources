    {
      "id": "EmgcG0QpQl5TqjShsODzf",
      "type": "text",
      "x": -1169.3518363551777,
      "y": 1023.1610273615806,
      "width": 793.1348401491887,
      "height": 149.68575363071255,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "RYyWijsoKs6BntHHFvPgY"
      ],
      "frameId": null,
      "index": "b0bV",
      "roundness": null,
      "seed": 1250780382,
      "version": 1477,
      "versionNonce": 1889879311,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779799853709,
      "link": null,
      "locked": false,
      "text": "• payload 如果太大，cell 并不会把全部数据都塞进本页，而是：                           \n    • 先放一部分 Local Payload                                                               \n    • 最后再跟一个 4 字节 overflow 首页号\n• SQLite 不是简单地“塞满本页再溢出”，而是要在 minLocal 和 maxLocal      \n  之间选一个局部大小，让 overflow 页尽量装满\n•  Total =  Local Payload On Btree Page + Overflow Payload On Overflow Pages",
      "fontSize": 19.958100484095006,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• payload 如果太大，cell 并不会把全部数据都塞进本页，而是：                                   \n    • 先放一部分 Local Payload                                                                  \n    • 最后再跟一个 4 字节 overflow 首页号\n• SQLite 不是简单地“塞满本页再溢出”，而是要在 minLocal 和 maxLocal      \n  之间选一个局部大小，让 overflow 页尽量装满\n•  Total =  Local Payload On Btree Page + Overflow Payload On Overflow Pages",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Qm45LyglHgu3ZWvJ3op56",
      "type": "text",
      "x": -1175.9819939174834,
      "y": 1205.9857590520066,
      "width": 1182.5830996134107,
      "height": 325.26499896596766,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "RYyWijsoKs6BntHHFvPgY"
      ],
      "frameId": null,
      "index": "b0c",
      "roundness": null,
      "seed": 389562114,
      "version": 1309,
      "versionNonce": 955763503,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779799853709,
      "link": null,
      "locked": false,
      "text": "  Overflow Page                                                           \n  +----------------------------------------------+                        \n  | Next Overflow Page No    (4 bytes)    | <- 0 表示链尾          \n  | Payload Chunk            (bytes)         | <- usableSize - 4      \n  +----------------------------------------------+                        \n                                                                          \n  Overflow Chain                                                          \n  +-----------------------------+      +-----------------------------+    \n  | Overflow Page #1        | ---> | Overflow Page #2       | ---> ...                                                                   \n  +-----------------------------+      +-----------------------------+    \n  | Next Page No             |       | Next Page No             |    \n  | Payload Chunk            |       | Payload Chunk            |    \n  +-----------------------------+      +-----------------------------+",
      "fontSize": 20.01630762867493,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  Overflow Page                                                           \n  +----------------------------------------------+                        \n  | Next Overflow Page No    (4 bytes)    | <- 0 表示链尾          \n  | Payload Chunk            (bytes)         | <- usableSize - 4      \n  +----------------------------------------------+                        \n                                                                          \n  Overflow Chain                                                          \n  +-----------------------------+      +-----------------------------+    \n  | Overflow Page #1        | ---> | Overflow Page #2       | ---> ...                                                                   \n  +-----------------------------+      +-----------------------------+    \n  | Next Page No             |       | Next Page No             |    \n  | Payload Chunk            |       | Payload Chunk            |    \n  +-----------------------------+      +-----------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
