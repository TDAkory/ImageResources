      "link": null,
      "locked": false,
      "text": "  Table Leaf        (0x0D)                                                                  \n  +----------------------------------------------+                                              \n  | Payload Size       (varint)                |                                              \n  | Rowid Key          (varint)                |                                              \n  | Payload Data      (bytes)                |                                              \n  | Overflow Page No (4 bytes, optional)  |                                              \n  +----------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  Table Leaf        (0x0D)                                                                  \n  +----------------------------------------------+                                              \n  | Payload Size       (varint)                |                                              \n  | Rowid Key          (varint)                |                                              \n  | Payload Data      (bytes)                |                                              \n  | Overflow Page No (4 bytes, optional)  |                                              \n  +----------------------------------------------+",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "4Bqm0tXpJ305F9uXqqN7-",
      "type": "text",
      "x": 3106.821807861328,
