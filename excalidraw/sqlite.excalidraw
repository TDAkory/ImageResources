      "seed": 732180290,
      "version": 349,
      "versionNonce": 1949238658,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777862533633,
      "link": null,
      "locked": false,
      "text": "  Cell Content Area with Holes                                            \n  +-----------------------+                \n  | cell A                 |                \n  +-----------------------+                \n  | freeblock             |                \n  +-----------------------+                \n  | cell B                 |                \n  +-----------------------+                \n  | tiny fragment       |             \n  +-----------------------+                \n  | cell C                 |                \n  +-----------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  Cell Content Area with Holes                                            \n  +-----------------------+                \n  | cell A                 |                \n  +-----------------------+                \n  | freeblock             |                \n  +-----------------------+                \n  | cell B                 |                \n  +-----------------------+                \n  | tiny fragment       |             \n  +-----------------------+                \n  | cell C                 |                \n  +-----------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GW6wqlO5UblGQNoLFvanx",
      "type": "text",
      "x": -1919.536806845926,
      "y": -310.52864063960556,
      "width": 654.7396850585938,
      "height": 600,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0l",
      "roundness": null,
      "seed": 445715486,
      "version": 283,
      "versionNonce": 1538467586,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777862535163,
      "link": null,
      "locked": false,
      "text": "  Database Header                                                         \n  +----------------------------------------------+                        \n  | First Freelist Trunk Page = P           |                        \n  | Total Freelist Page Count = N          |                        \n  +----------------------------------------------+                        \n                                                                          \n  Freelist                                                                \n  P --> Trunk Page --> next trunk --> ...                                 \n         |                                                                \n         +--> leaf page                                                   \n         +--> leaf page                                                   \n         +--> leaf page                                                   \n                                                                          \n  单个 trunk page 的结构：                                                \n                                                                          \n  Freelist Trunk Page                                                     \n  +--------------------------------------------------+                    \n  | Next Trunk Page No.        (4 bytes)       |                    \n  | Leaf Pointer Count         (4 bytes)        |                    \n  | Leaf Page No. #1           (4 bytes)        |                    \n  | Leaf Page No. #2           (4 bytes)       |                    \n  | Leaf Page No. #3           (4 bytes)       |                    \n  | ...                                                 |                    \n  +--------------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  Database Header                                                         \n  +----------------------------------------------+                        \n  | First Freelist Trunk Page = P           |                        \n  | Total Freelist Page Count = N          |                        \n  +----------------------------------------------+                        \n                                                                          \n  Freelist                                                                \n  P --> Trunk Page --> next trunk --> ...                                 \n         |                                                                \n         +--> leaf page                                                   \n         +--> leaf page                                                   \n         +--> leaf page                                                   \n                                                                          \n  单个 trunk page 的结构：                                                \n                                                                          \n  Freelist Trunk Page                                                     \n  +--------------------------------------------------+                    \n  | Next Trunk Page No.        (4 bytes)       |                    \n  | Leaf Pointer Count         (4 bytes)        |                    \n  | Leaf Page No. #1           (4 bytes)        |                    \n  | Leaf Page No. #2           (4 bytes)       |                    \n  | Leaf Page No. #3           (4 bytes)       |                    \n  | ...                                                 |                    \n  +--------------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "QD6GjmFjuBUuGbDmz0Rv3",
      "type": "text",
      "x": -1162.877443886311,
      "y": -2125.0949171416923,
      "width": 708.69970703125,
      "height": 950,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0m",
      "roundness": null,
      "seed": 1385803330,
      "version": 264,
      "versionNonce": 1744209182,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777863111314,
      "link": null,
      "locked": false,
      "text": "  逻辑表到物理表的映射\n  sqlite_schema\n  +-------------------------------------------------------------------------+        \n  | type   | name       | tbl_name | rootpage | sql                    |         \n  +-------------------------------------------------------------------------+        \n  | table  | users       | users     | 2          | CREATE TABLE... |         \n  | index  | idx_name  | users     | 5          | CREATE INDEX... |         \n  | table  | orders     | orders    | 8          | CREATE TABLE... |         \n  +------------------------------------------------------------------------+\n\n\n  sqlite_schema.rootpage mapping                                          \n  +------------------------------------------------------------+                \n  | logical object      | root page | physical tree        |                \n  +------------------------------------------------------------+                \n  | table users         | 2         | B-tree rooted at 2 |                \n  | index idx_name    | 5         | B-tree rooted at 5 |                \n  | table orders       | 8         | B-tree rooted at 8 |                \n  +-----------------------------------------------------------+\n\n  Database File                                                           \n  +------------------------+                                              \n  | Page 1                 | <- db header + sqlite_schema root btree      \n  +------------------------+                                              \n  | Page 2                 | <- users table root                          \n  +------------------------+                                              \n  | Page 3                 | <- users subtree page                        \n  +------------------------+                                              \n  | Page 4                 | <- users subtree page                        \n  +------------------------+                                              \n  | Page 5                 | <- idx_name root                             \n  +------------------------+                                              \n  | Page 6                 | <- idx_name subtree page                     \n  +------------------------+                                              \n  | Page 7                 | <- overflow / freelist / etc.                \n  +------------------------+                                              \n  | Page 8                 | <- orders table root                         \n  +------------------------+ ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  逻辑表到物理表的映射\n  sqlite_schema\n  +-------------------------------------------------------------------------+        \n  | type   | name       | tbl_name | rootpage | sql                    |         \n  +-------------------------------------------------------------------------+        \n  | table  | users       | users     | 2          | CREATE TABLE... |         \n  | index  | idx_name  | users     | 5          | CREATE INDEX... |         \n  | table  | orders     | orders    | 8          | CREATE TABLE... |         \n  +------------------------------------------------------------------------+\n\n\n  sqlite_schema.rootpage mapping                                          \n  +------------------------------------------------------------+                \n  | logical object      | root page | physical tree        |                \n  +------------------------------------------------------------+                \n  | table users         | 2         | B-tree rooted at 2 |                \n  | index idx_name    | 5         | B-tree rooted at 5 |                \n  | table orders       | 8         | B-tree rooted at 8 |                \n  +-----------------------------------------------------------+\n\n  Database File                                                           \n  +------------------------+                                              \n  | Page 1                 | <- db header + sqlite_schema root btree      \n  +------------------------+                                              \n  | Page 2                 | <- users table root                          \n  +------------------------+                                              \n  | Page 3                 | <- users subtree page                        \n  +------------------------+                                              \n  | Page 4                 | <- users subtree page                        \n  +------------------------+                                              \n  | Page 5                 | <- idx_name root                             \n  +------------------------+                                              \n  | Page 6                 | <- idx_name subtree page                     \n  +------------------------+                                              \n  | Page 7                 | <- overflow / freelist / etc.                \n  +------------------------+                                              \n  | Page 8                 | <- orders table root                         \n  +------------------------+ ",
      "autoResize": true,
      "lineHeight": 1.25
    },
