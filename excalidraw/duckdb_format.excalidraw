      "isDeleted": false,
      "boundElements": [],
      "updated": 1772450417615,
      "link": null,
      "locked": false,
      "text": "    +-------------------- WAL 文件 --------------------------+\n    | [Header] | [Entry 1] | [Entry 2] | ... | [Entry N] |\n    +----------------------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    +-------------------- WAL 文件 --------------------------+\n    | [Header] | [Entry 1] | [Entry 2] | ... | [Entry N] |\n    +----------------------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WgCLcxOsbeD1oqb3wkFRk",
      "type": "text",
      "x": 1238.1504313151042,
      "y": -112.33723958333337,
      "width": 448.559326171875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "28_9G39gF26xnAwTA7tfi"
      ],
      "frameId": null,
      "index": "b2e",
      "roundness": null,
      "seed": 598506019,
      "version": 179,
      "versionNonce": 1823907726,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772450417615,
      "link": null,
      "locked": false,
      "text": "    +--------------非加密 Entry-------------------+\n    | size (u64) | checksum (u64)  |  payload...\n    +------------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    +--------------非加密 Entry-------------------+\n    | size (u64) | checksum (u64)  |  payload...\n    +------------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aNd-7jeCBZcY8_q3QmI3c",
      "type": "text",
      "x": 1240.4713236490886,
      "y": -20.33333333333337,
      "width": 703.37890625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "28_9G39gF26xnAwTA7tfi"
      ],
      "frameId": null,
      "index": "b2f",
      "roundness": null,
      "seed": 329518531,
      "version": 169,
      "versionNonce": 68648398,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772450417615,
      "link": null,
      "locked": false,
      "text": "    +----------------------------加密 Entry--------------------------------------+\n    | size (u64) | nonce(12B) | ciphertext(checksum+payload) | tag(16B)\n    +-------------------------------------------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    +----------------------------加密 Entry--------------------------------------+\n    | size (u64) | nonce(12B) | ciphertext(checksum+payload) | tag(16B)\n    +-------------------------------------------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "roHM1IozWYJdNuNCaKBef",
      "type": "text",
      "x": 1744.6467132568364,
      "y": 650.1692708333335,
      "width": 203.01991271972656,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
