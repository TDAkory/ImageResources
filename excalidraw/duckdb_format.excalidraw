      "link": null,
      "locked": false,
      "text": "     DataTable\n    +------------------+\n    | RowGroup #0  |\n    +------------------+\n    | RowGroup #1  |\n    +------------------+\n    | RowGroup ...   |\n    +------------------+\n    | RowGroup #n  |\n    +------------------+",
      "fontSize": 20,
      "fontFamily": 5,
