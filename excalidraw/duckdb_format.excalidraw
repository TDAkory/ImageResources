      "updated": 1772158408550,
      "link": null,
      "locked": false,
      "text": "    DatabaseHeader (DatabaseHeader::Write)\n    +-------------------------------+\n    | Checksum（8B）            |\n    | iteration（8B）             |\n    | meta_block ptr （8B）    |\n    | free_list ptr （8B）       |\n    | block_count （8B）        |\n    | block_alloc_size（8B）    |\n    | vector_size（8B）         |\n    | serialization_compatibility|\n    +-------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    DatabaseHeader (DatabaseHeader::Write)\n    +-------------------------------+\n    | Checksum（8B）            |\n    | iteration（8B）             |\n    | meta_block ptr （8B）    |\n    | free_list ptr （8B）       |\n    | block_count （8B）        |\n    | block_alloc_size（8B）    |\n    | vector_size（8B）         |\n    | serialization_compatibility|\n    +-------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
