      "versionNonce": 811605842,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772450422030,
      "link": null,
      "locked": false,
      "text": "     DataTable\n    +------------------+\n    | RowGroup #0  |\n    +------------------+\n    | RowGroup #1  |\n    +------------------+\n    | RowGroup ...   |\n    +------------------+\n    | RowGroup #n  |\n    +------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "     DataTable\n    +------------------+\n    | RowGroup #0  |\n    +------------------+\n    | RowGroup #1  |\n    +------------------+\n    | RowGroup ...   |\n    +------------------+\n    | RowGroup #n  |\n    +------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-prvWagEb-6h9vCxcVrwb",
      "type": "text",
      "x": 2889.6251169840502,
      "y": -9.225260416666629,
