        }
      ],
      "updated": 1772158310423,
      "link": null,
      "locked": false,
      "text": "    +-----------------------+ 0\n    | MainHeader          | \n    +-----------------------+ 4KB\n    | DatabaseHeader A | \n    +-----------------------+ 8KB\n    | DatabaseHeader B |\n    +-----------------------+ 12KB = BLOCK_START\n    | 数据块 #0           |\n    +-----------------------+ 12 + 256KB\n    | 数据块 #1            |\n    +-----------------------+\n    | ...                     |\n    +-----------------------+\n    | 数据块 #N            |\n    +-----------------------+ 12 + N * 256 KB",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    +-----------------------+ 0\n    | MainHeader          | \n    +-----------------------+ 4KB\n    | DatabaseHeader A | \n    +-----------------------+ 8KB\n    | DatabaseHeader B |\n    +-----------------------+ 12KB = BLOCK_START\n    | 数据块 #0           |\n    +-----------------------+ 12 + 256KB\n    | 数据块 #1            |\n    +-----------------------+\n    | ...                     |\n    +-----------------------+\n    | 数据块 #N            |\n    +-----------------------+ 12 + N * 256 KB",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "DY-vFu9nsqj01HO8D0XRo",
      "type": "text",
      "x": 2928.877029418945,
      "y": -205.54036458333343,
      "width": 775.1998291015625,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "tPo44cL552UyVGlCnh_R4"
      ],
      "frameId": null,
      "index": "b2k",
      "roundness": null,
      "seed": 841601709,
      "version": 210,
      "versionNonce": 1391942541,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772158310423,
      "link": null,
      "locked": false,
      "text": "单文件存储（.duckdb）以“页式头 + 块区”的结构组织\n文件前 3 个页头（每页头大小默认 4KB，Storage::FILE_HEADER_SIZE）依次为：\n  • MainHeader（魔术字、版本、加密与数据库标识）\n  • DatabaseHeader（活动版）\n  • DatabaseHeader（备用版，checkpoint 时翻转）",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "单文件存储（.duckdb）以“页式头 + 块区”的结构组织\n文件前 3 个页头（每页头大小默认 4KB，Storage::FILE_HEADER_SIZE）依次为：\n  • MainHeader（魔术字、版本、加密与数据库标识）\n  • DatabaseHeader（活动版）\n  • DatabaseHeader（备用版，checkpoint 时翻转）",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "uHGXAjH11peYcsJVU1CHH",
      "type": "text",
      "x": 2430.5957794189453,
      "y": -225.88541666666674,
      "width": 350.9398193359375,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "tPo44cL552UyVGlCnh_R4"
      ],
      "frameId": null,
      "index": "b2l",
      "roundness": null,
      "seed": 626250157,
      "version": 524,
      "versionNonce": 1342071277,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "PAd7SLTyKpvgLyxNUB9u4",
          "type": "arrow"
        }
      ],
      "updated": 1772158310423,
      "link": null,
      "locked": false,
      "text": "    MainHeader (MainHeader::Write)\n    +------------------------------------+\n    | Checksum（8B）                 |\n    | MAGIC \"DUCK\"                   |\n    | version_number                   |\n    | flags[4]                           |\n    | DUCKDB_VERSION (32B)     |\n    | DUCKDB_SOURCE_ID (32B) |\n    | encryption_metadata (8B)     |\n    | db_identifier (16B)              |\n    | encrypted_canary (8B)         |\n    | canary_iv (16B)                  |\n    | canary_tag (16B)                |\n    +------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    MainHeader (MainHeader::Write)\n    +------------------------------------+\n    | Checksum（8B）                 |\n    | MAGIC \"DUCK\"                   |\n    | version_number                   |\n    | flags[4]                           |\n    | DUCKDB_VERSION (32B)     |\n    | DUCKDB_SOURCE_ID (32B) |\n    | encryption_metadata (8B)     |\n    | db_identifier (16B)              |\n    | encrypted_canary (8B)         |\n    | canary_iv (16B)                  |\n    | canary_tag (16B)                |\n    +------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IeUWXLEho5nIqZYQZ3SCT",
      "type": "text",
      "x": 2431.8312733968087,
      "y": 138.68489583333337,
      "width": 435.4996643066406,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
