      "verticalAlign": "top",
      "containerId": null,
      "originalText": "     DataTable\n    +------------------+\n    | RowGroup #0  |\n    +------------------+\n    | RowGroup #1  |\n    +------------------+\n    | RowGroup ...   |\n    +------------------+\n    | RowGroup #n  |\n    +------------------+",
