      "isDeleted": false,
      "boundElements": [],
      "updated": 1772450417615,
      "link": null,
      "locked": false,
      "text": "    +-------------------- WAL 文件 --------------------------+\n    | [Header] | [Entry 1] | [Entry 2] | ... | [Entry N] |\n    +----------------------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    +-------------------- WAL 文件 --------------------------+\n    | [Header] | [Entry 1] | [Entry 2] | ... | [Entry N] |\n    +----------------------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WgCLcxOsbeD1oqb3wkFRk",
      "type": "text",
      "x": 1238.1504313151042,
      "y": -112.33723958333337,
      "width": 448.559326171875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "28_9G39gF26xnAwTA7tfi"
      ],
