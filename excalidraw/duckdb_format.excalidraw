      "isDeleted": false,
      "boundElements": [],
      "updated": 1772450417615,
      "link": null,
      "locked": false,
      "text": "    +--------------非加密 Entry-------------------+\n    | size (u64) | checksum (u64)  |  payload...\n    +------------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    +--------------非加密 Entry-------------------+\n    | size (u64) | checksum (u64)  |  payload...\n    +------------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aNd-7jeCBZcY8_q3QmI3c",
      "type": "text",
      "x": 1240.4713236490886,
      "y": -20.33333333333337,
      "width": 703.37890625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
