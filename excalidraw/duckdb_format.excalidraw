    },
    {
      "id": "apIJxIVZkkNqvkxMuTAJf",
      "type": "text",
      "x": 3136.6504669189467,
      "y": 335.49479166666663,
      "width": 800,
      "height": 650,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2s",
      "roundness": null,
      "seed": 319310866,
      "version": 3,
      "versionNonce": 1009643410,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1772450535576,
      "link": null,
      "locked": false,
      "text": "┌───────────────────────────────────────\n───────────────────────────────┐\n│                            256KB                                    │\n├──────────────┬────────────────────────\n───────────────────────────────┤\n│    Offset    │                     Content                          │\n├──────────────┼────────────────────────\n───────────────────────────────┤\n│      0       │ Checksum (8B)                                        │\n├──────────────┼────────────────────────\n───────────────────────────────┤\n│      8       │ Meta Block 0 (4088B)                                │\n├──────────────┼────────────────────────\n───────────────────────────────┤\n│  8+1*4088    │ Meta Block 1 (4088B)                                │\n├──────────────┼────────────────────────\n───────────────────────────────┤\n│     ...      │                        ...                           │\n├──────────────┼────────────────────────\n───────────────────────────────┤\n│  8+63*4088   │ Meta Block 63 (4088B)                               │\n├──────────────┼────────────────────────\n───────────────────────────────┤\n│  8+64*4088   │ unused (8*64-8=504B)                                │\n└──────────────┴────────────────────────\n───────────────────────────────┘",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "┌──────────────────────────────────────────────────────────────────────┐\n│                            256KB                                    │\n├──────────────┬───────────────────────────────────────────────────────┤\n│    Offset    │                     Content                          │\n├──────────────┼───────────────────────────────────────────────────────┤\n│      0       │ Checksum (8B)                                        │\n├──────────────┼───────────────────────────────────────────────────────┤\n│      8       │ Meta Block 0 (4088B)                                │\n├──────────────┼───────────────────────────────────────────────────────┤\n│  8+1*4088    │ Meta Block 1 (4088B)                                │\n├──────────────┼───────────────────────────────────────────────────────┤\n│     ...      │                        ...                           │\n├──────────────┼───────────────────────────────────────────────────────┤\n│  8+63*4088   │ Meta Block 63 (4088B)                               │\n├──────────────┼───────────────────────────────────────────────────────┤\n│  8+64*4088   │ unused (8*64-8=504B)                                │\n└──────────────┴───────────────────────────────────────────────────────┘",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "T6Lu1gst3uZzl_TTZ6y22",
      "type": "text",
      "x": 2898.024164835612,
      "y": 500.41015624999966,
      "width": 415.87957763671875,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2t",
      "roundness": null,
      "seed": 50219022,
      "version": 494,
      "versionNonce": 233705874,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772454432888,
      "link": null,
      "locked": false,
      "text": "           Metadata\n    +-----------------------+ 0\n    | Checksum            | \n    +-----------------------+ 8B\n    | Meta Block 0       | \n    +-----------------------+ 8 + 4088 B\n    | Meta Block 2       |\n    +-----------------------+ 8 + 2 * 4088 B\n    | ...                     |\n    +-----------------------+\n    |Meta Block 63       |\n    +-----------------------+ 8 + 63 * 4088 B\n    |Unuse                  |\n    +-----------------------+ 256 KB",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "           Metadata\n    +-----------------------+ 0\n    | Checksum            | \n    +-----------------------+ 8B\n    | Meta Block 0       | \n    +-----------------------+ 8 + 4088 B\n    | Meta Block 2       |\n    +-----------------------+ 8 + 2 * 4088 B\n    | ...                     |\n    +-----------------------+\n    |Meta Block 63       |\n    +-----------------------+ 8 + 63 * 4088 B\n    |Unuse                  |\n    +-----------------------+ 256 KB",
      "autoResize": true,
      "lineHeight": 1.25
    },
