      "text": "           Metadata\n    +-----------------------+ 0\n    | Checksum            | \n    +-----------------------+ 8B\n    | Meta Block 0       | \n    +-----------------------+ 8 + 4088 B\n    | Meta Block 2       |\n    +-----------------------+ 8 + 2 * 4088 B\n    | ...                     |\n    +-----------------------+\n    |Meta Block 63       |\n    +-----------------------+ 8 + 63 * 4088 B\n    |Unuse                  |\n    +-----------------------+ 256 KB",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "           Metadata\n    +-----------------------+ 0\n    | Checksum            | \n    +-----------------------+ 8B\n    | Meta Block 0       | \n    +-----------------------+ 8 + 4088 B\n    | Meta Block 2       |\n    +-----------------------+ 8 + 2 * 4088 B\n    | ...                     |\n    +-----------------------+\n    |Meta Block 63       |\n    +-----------------------+ 8 + 63 * 4088 B\n    |Unuse                  |\n    +-----------------------+ 256 KB",
      "autoResize": true,
      "lineHeight": 1.25
