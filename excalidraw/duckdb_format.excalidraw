      "updated": 1772518248364,
      "link": null,
      "locked": false,
      "text": "2. Catalog 写入是一个条目列表形式，每个条目自描述类型（2B field_id）与自身内容",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. Catalog 写入是一个条目列表形式，每个条目自描述类型（2B field_id）与自身内容",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "0dFQwTGsKqCX1tZstf44x",
      "type": "text",
      "x": 3549.4547068278025,
      "y": 709.4921874999998,
      "width": 758.779541015625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3H",
      "roundness": null,
      "seed": 57256082,
      "version": 180,
      "versionNonce": 1503701266,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772537911362,
      "link": null,
      "locked": false,
      "text": "  +-----------------------+----------------------------+----------------------------------+\n  | FieldTag=100 (2B) | EntryCount u64 (8B)  | CatalogEntryObject[0..N-1]  |\n  +-----------------------+----------------------------+----------------------------------+\n  |←    属性号        →|←     列表元素个数    →|← N 个目录条目（变长写入）→|",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  +-----------------------+----------------------------+----------------------------------+\n  | FieldTag=100 (2B) | EntryCount u64 (8B)  | CatalogEntryObject[0..N-1]  |\n  +-----------------------+----------------------------+----------------------------------+\n  |←    属性号        →|←     列表元素个数    →|← N 个目录条目（变长写入）→|",
      "autoResize": true,
      "lineHeight": 1.25
    },
