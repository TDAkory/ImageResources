      "text": "  索引旧版兼容（仅 INDEX）\n  +------------------+----------------------------------+\n  | Field: 101 (2B) | root_block_pointer (12B)   |\n  +------------------+----------------------------------+\n  |←  旧版可选  →| block_id (8B) + offset (4B) |",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  索引旧版兼容（仅 INDEX）\n  +------------------+----------------------------------+\n  | Field: 101 (2B) | root_block_pointer (12B)   |\n  +------------------+----------------------------------+\n  |←  旧版可选  →| block_id (8B) + offset (4B) |",
      "autoResize": true,
      "lineHeight": 1.25
    },
