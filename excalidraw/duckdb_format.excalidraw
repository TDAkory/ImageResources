          "type": "arrow"
        }
      ],
      "updated": 1772158310423,
      "link": null,
      "locked": false,
      "text": "    MainHeader (MainHeader::Write)\n    +------------------------------------+\n    | Checksum（8B）                 |\n    | MAGIC \"DUCK\"                   |\n    | version_number                   |\n    | flags[4]                           |\n    | DUCKDB_VERSION (32B)     |\n    | DUCKDB_SOURCE_ID (32B) |\n    | encryption_metadata (8B)     |\n    | db_identifier (16B)              |\n    | encrypted_canary (8B)         |\n    | canary_iv (16B)                  |\n    | canary_tag (16B)                |\n    +------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    MainHeader (MainHeader::Write)\n    +------------------------------------+\n    | Checksum（8B）                 |\n    | MAGIC \"DUCK\"                   |\n    | version_number                   |\n    | flags[4]                           |\n    | DUCKDB_VERSION (32B)     |\n    | DUCKDB_SOURCE_ID (32B) |\n    | encryption_metadata (8B)     |\n    | db_identifier (16B)              |\n    | encrypted_canary (8B)         |\n    | canary_iv (16B)                  |\n    | canary_tag (16B)                |\n    +------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IeUWXLEho5nIqZYQZ3SCT",
      "type": "text",
