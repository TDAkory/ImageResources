      "text": "+====================================================================+\n    | CatalogCheckpoint                                                   |\n    |                                                                    |\n    |  Field[100] \"catalog_entries\": List<N>                              |\n    |    ├─ Entry[0]  → CatalogEntryObject                               |\n    |    ├─ Entry[1]  → CatalogEntryObject                               |\n    |    ├─ ...                                                          |\n    |    └─ Entry[N-1] → CatalogEntryObject                              |\n\n+====================================================================+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "+====================================================================+\n    | CatalogCheckpoint                                                   |\n    |                                                                    |\n    |  Field[100] \"catalog_entries\": List<N>                              |\n    |    ├─ Entry[0]  → CatalogEntryObject                               |\n    |    ├─ Entry[1]  → CatalogEntryObject                               |\n    |    ├─ ...                                                          |\n    |    └─ Entry[N-1] → CatalogEntryObject                              |\n    +====================================================================+",
      "autoResize": false,
      "lineHeight": 1.25
