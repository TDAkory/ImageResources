      "seed": 2139302542,
      "version": 669,
      "versionNonce": 790289102,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783080485369,
      "link": null,
      "locked": false,
      "text": "单个 block 在 SST 中的物理布局\n+----------------------------+---------------------------+-----------------+\n| block_data: uint8[n]    | compression_type 1B  | checksum 4B  |\n+----------------------------+---------------------------+------------------+\n^ offset                    ^ BlockHandle.size 不包含 trailer",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "单个 block 在 SST 中的物理布局\n+----------------------------+---------------------------+-----------------+\n| block_data: uint8[n]    | compression_type 1B  | checksum 4B  |\n+----------------------------+---------------------------+------------------+\n^ offset                    ^ BlockHandle.size 不包含 trailer",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IVMB4qU_2QCuAE16k8fqS",
      "type": "text",
      "x": 3866.510678245907,
      "y": 790.5724981398812,
      "width": 696.038818359375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0r",
      "roundness": null,
      "seed": 257129362,
      "version": 349,
      "versionNonce": 1020416270,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783080485369,
      "link": null,
      "locked": false,
      "text": "Data block\n+----------------------------------------------------------------------------------+\n| entry[0]: shared=0 | unshared=len(key0) | value_len | key0_delta | ... |\n| entry[1]: shared=n   unshared=len(d1)    | value_len | key1_delta  | ... |\n| entry[2]: shared=n | unshared=len(d2)   | value_len | key2_delta | ... |\n| ...                                                                                  |\n+----------------------------------------------------------------------------------+\n| restart[0] | restart[1] | restart[2] | ... | num_restarts                |\n+----------------------------------------------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Data block\n+----------------------------------------------------------------------------------+\n| entry[0]: shared=0 | unshared=len(key0) | value_len | key0_delta | ... |\n| entry[1]: shared=n   unshared=len(d1)    | value_len | key1_delta  | ... |\n| entry[2]: shared=n | unshared=len(d2)   | value_len | key2_delta | ... |\n| ...                                                                                  |\n+----------------------------------------------------------------------------------+\n| restart[0] | restart[1] | restart[2] | ... | num_restarts                |\n+----------------------------------------------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "md2ApUrP-mfRD3HPpXtGP",
      "type": "text",
