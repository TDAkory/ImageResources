      "updated": 1783080485369,
      "link": null,
      "locked": false,
      "text": "Metaindex block \n+-------------------------+--------------------------------+\n| \"rocksdb.properties\"  | BlockHandle(offset, size)  |\n| \"rocksdb.index\"        | BlockHandle(offset, size)  |\n| \"rocksdb.range_del\"   | BlockHandle(offset, size)  |\n| \"fullfilter.xxx\"          | BlockHandle(offset, size)  |\n| ...                         | ...                              |\n+--------------------------+--------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Metaindex block \n+-------------------------+--------------------------------+\n| \"rocksdb.properties\"  | BlockHandle(offset, size)  |\n| \"rocksdb.index\"        | BlockHandle(offset, size)  |\n| \"rocksdb.range_del\"   | BlockHandle(offset, size)  |\n| \"fullfilter.xxx\"          | BlockHandle(offset, size)  |\n| ...                         | ...                              |\n+--------------------------+--------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
