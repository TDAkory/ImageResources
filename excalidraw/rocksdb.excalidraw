      "updated": 1783080744853,
      "link": null,
      "locked": false,
      "text": "Internal Key 的直观布局\n\n+----------------------------+---------------------------------------------+\n| user_key bytes          | tag: fixed64(seq << 8 | value_type)   |\n+----------------------------+---------------------------------------------+\n|<---------------------------- Internal Key ----------------------------->|\n\ntag 的逻辑含义\n+-------------------------------- 64 bits -------------------------------+\n|      sequence number (高 56 bits)    | value_type (低 8 bits)  |\n+-------------------------------------------------------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Internal Key 的直观布局\n\n+----------------------------+---------------------------------------------+\n| user_key bytes          | tag: fixed64(seq << 8 | value_type)   |\n+----------------------------+---------------------------------------------+\n|<---------------------------- Internal Key ----------------------------->|\n\ntag 的逻辑含义\n+-------------------------------- 64 bits -------------------------------+\n|      sequence number (高 56 bits)    | value_type (低 8 bits)  |\n+-------------------------------------------------------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wq2cWWwmJrK2xTDA8d5Zh",
      "type": "text",
      "x": 2516.3105089573273,
      "y": 916.8655133928573,
      "width": 506.97918701171875,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
