      "seed": 1877526738,
      "version": 277,
      "versionNonce": 1716784526,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783076659973,
      "link": null,
      "locked": false,
      "text": "WriteBatch payload 的直观布局\n\n<beginning_of_writebatch>\n+---------------------------+--------------------+\n| sequence: fixed64      | count: fixed32  |\n+---------------------------+--------------------+\n| record #0                                      |\n+------------------------------------------------+\n| record #1                                      |\n+------------------------------------------------+\n| ...                                               |\n+------------------------------------------------+\n| record #N                                     |\n+------------------------------------------------+\n<end_of_writebatch>\n\n其中单个 record 的形态取决于 type\n+------------+---------+----------------------------+\n| type       | key     | value / operand / cfid  |\n+------------+---------+----------------------------+",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WriteBatch payload 的直观布局\n\n<beginning_of_writebatch>\n+---------------------------+--------------------+\n| sequence: fixed64      | count: fixed32  |\n+---------------------------+--------------------+\n| record #0                                      |\n+------------------------------------------------+\n| record #1                                      |\n+------------------------------------------------+\n| ...                                               |\n+------------------------------------------------+\n| record #N                                     |\n+------------------------------------------------+\n<end_of_writebatch>\n\n其中单个 record 的形态取决于 type\n+------------+---------+----------------------------+\n| type       | key     | value / operand / cfid  |\n+------------+---------+----------------------------+",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TZG6cKdmapV-QCOIhiNUx",
      "type": "rectangle",
      "x": 2491.1666666666665,
