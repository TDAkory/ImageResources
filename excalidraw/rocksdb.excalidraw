      "isDeleted": false,
      "boundElements": null,
      "updated": 1783242026452,
      "link": null,
      "locked": false,
      "text": "MemTable entry 的直观布局\n\n+-------------------------------+--------------------------+\n| varint32 internal_key_sz | internal_key bytes    |\n+-------------------------------+--------------------------+\n| varint32 value_sz          | value bytes             |\n+-------------------------------+--------------------------+\n| optional protection / checksum bytes               |\n+-----------------------------------------------------------+\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MemTable entry 的直观布局\n\n+-------------------------------+--------------------------+\n| varint32 internal_key_sz | internal_key bytes    |\n+-------------------------------+--------------------------+\n| varint32 value_sz          | value bytes             |\n+-------------------------------+--------------------------+\n| optional protection / checksum bytes               |\n+-----------------------------------------------------------+\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
